--// Radeon Autofarm (Auto-start)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer

-- Character and humanoid setup
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local HRP = Character:WaitForChild("HumanoidRootPart")

Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)

-- Lobby position
local LobbyPos = workspace.Lobby.VoteStation.pad3.Position

-- Notification
local function Notify(title, text, dur)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = dur or 3
    })
end

-- Refresh character references on respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
    HRP = char:WaitForChild("HumanoidRootPart")
    Humanoid = char:WaitForChild("Humanoid")
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
end)

--// Autofarm enabled by default
getgenv().NewAutofarm = true
Notify("Autofarm", "Enabled", 2)

--=== Start of Radeon autofarm logic ===--
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local ScreenGui = PlayerGui:WaitForChild("ScreenGui")
local UI = ScreenGui:WaitForChild("UI")
local TargetLabel = UI:WaitForChild("Target")
local TargetText = TargetLabel:WaitForChild("TargetText")

local GameModeLabel = UI:WaitForChild("textD"):WaitForChild("Gamemode"):WaitForChild("textD")

local targetChar = nil
local targetHRP = nil
local attacking = false
local waitingForRound = false
local gameMode = "Classic"

GameModeLabel:GetPropertyChangedSignal("Text"):Connect(function()
    gameMode = GameModeLabel.Text
end)

local function getTargetByUI()
    if TargetLabel.Visible and TargetText.Text ~= "" then
        return Players:FindFirstChild(TargetText.Text)
    end
end

local function getClosestTarget()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = workspace:FindFirstChild(plr.Name)
            if char and char:FindFirstChild("HumanoidRootPart") then
                if (LobbyPos - char.HumanoidRootPart.Position).Magnitude > 300 then
                    return char
                end
            end
        end
    end
    return nil
end

local function getGameModeTarget(isZombie, opposite)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = workspace:FindFirstChild(plr.Name)
            if char and char:FindFirstChild("Torso") then
                local hasZombie = char.Torso:FindFirstChild("zombbox")
                if isZombie and hasZombie then
                    return char
                elseif not isZombie and not hasZombie and opposite then
                    return char
                end
            end
        end
    end
    return nil
end

local function resolveTarget()
    if gameMode == "Classic" and TargetLabel.Visible then
        local uiTarget = getTargetByUI()
        if uiTarget then
            return workspace:FindFirstChild(uiTarget.Name)
        end
    end
    if gameMode == "Free For All" then
        return getClosestTarget()
    end
    if gameMode == "Juggernaut" then
        local isZombie = Character and Character:FindFirstChild("Torso") and Character.Torso:FindFirstChild("zombbox")
        if isZombie then
            return getClosestTarget()
        else
            return getGameModeTarget(false, false)
        end
    end
    if gameMode == "Infection" then
        local isZombie = Character and Character:FindFirstChild("Torso") and Character.Torso:FindFirstChild("zombbox")
        if isZombie then
            return getGameModeTarget(true, true)
        else
            return getGameModeTarget(true, false)
        end
    end
    return nil
end

RunService.RenderStepped:Connect(function()
    if not getgenv().NewAutofarm then return end
    if not HRP or not Humanoid then return end

    local dist = (LobbyPos - HRP.Position).Magnitude

    if dist > 300 and not waitingForRound and gameMode == "Classic" then
        task.wait(9.5)
        waitingForRound = true
    elseif dist < 300 then
        waitingForRound = false
    end

    if dist > 300 and workspace.Gravity ~= 0 then
        workspace.Gravity = 0
    elseif dist < 300 and Character and HRP and workspace.Gravity == 0 then
        workspace.Gravity = 196.2
        Humanoid.Health = 0
        return
    end

    if dist > 300 then
        targetChar = resolveTarget()
        if targetChar then
            targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                local newCFrame = targetHRP.CFrame * CFrame.new(-2, -2, 2)
                local tween = TweenService:Create(HRP, TweenInfo.new(0, Enum.EasingStyle.Linear), {CFrame = newCFrame})
                tween:Play()

                if not attacking then
                    attacking = true
                    local hitCheck = LocalPlayer.PlayerScripts:FindFirstChild("localknifehandler")
                    if hitCheck and hitCheck:FindFirstChild("HitCheck") then
                        hitCheck.HitCheck:Fire(targetChar)
                    end
                    task.wait(1)
                    attacking = false
                end
            end
        end
    end
end)
